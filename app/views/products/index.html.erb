<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>🛒 Our Products</h1>
  <%= link_to "Add New Product", new_product_path, class: "btn btn-success" %>
</div>

<div class="row">
  <% @products.each do |product| %>
    <div class="col-md-4 mb-4">
      <div class="card h-100 shadow-sm">
        <% if product.image_url.present? %>
          <img src="<%= product.image_url %>" class="card-img-top" style="height: 200px; object-fit: cover;">
        <% end %>
        <div class="card-body">
          <h5 class="card-title"><%= product.name %></h5>
          <p class="card-text text-muted"><%= product.description %></p>
          <h4 class="text-success">€<%= product.price %></h4>
        </div>
        <div class="card-footer d-flex justify-content-between">
          <%= link_to "View", product, class: "btn btn-primary btn-sm" %>
          <%= button_to "🛒 Add to Cart", cart_items_path(product_id: product.id), method: :post, class: "btn btn-success btn-sm" %>
          <%= link_to "Edit", edit_product_path(product), class: "btn btn-warning btn-sm" %>
          <%= link_to "Delete", product, data: {turbo_method: :delete, turbo_confirm: "Sure?"}, class: "btn btn-danger btn-sm" %>
        </div>
      </div>
    </div>
  <% end %>
</div>
